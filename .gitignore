#-------------------------
# OS
#-------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msm
*.msp
*.lnk
*~
.directory
.Trash-*

#-------------------------
# Secrets / local env
#-------------------------
# Template (commit): file `env` (no leading dot).
# Runtime secrets (never commit):
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
auth.json
credentials.json
id_rsa
id_rsa.pub

#-------------------------
# CodeIgniter writable (runtime only)
# Keep directory placeholders; ignore all generated content.
#-------------------------
/writable/cache/**
!/writable/cache/index.html

/writable/logs/**
!/writable/logs/index.html

/writable/session/**
!/writable/session/index.html

/writable/uploads/**
!/writable/uploads/index.html

/writable/debugbar/**
!/writable/debugbar/index.html

# Any future runtime subdirs under writable
/writable/**/*
!/writable/**/
!/writable/**/index.html
!/writable/.htaccess
!/writable/index.html

php_errors.log
*.log

#-------------------------
# Dependencies
#-------------------------
/vendor/
/node_modules/

#-------------------------
# Build / coverage / test artifacts
#-------------------------
/build/
/coverage/
/tmp/
/temp/
.phpunit.result.cache
.phpunit.cache
phpunit.result.cache
.phpunit.cache/
clover.xml
junit.xml
*.lcov

